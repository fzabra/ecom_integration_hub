{
  "name": "ecom-integration-hub",
  "private": true,
  "version": "1.0.0",
  "description": "Portfolio ecommerce with API, SaaS, ERP, PIM, AI and analytics integrations",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace services/integration-worker run dev",
    "start": "npm-run-all --parallel start:*",
    "start:api": "npm --workspace apps/api run start",
    "start:web": "npm --workspace apps/web run start",
    "start:worker": "npm --workspace services/integration-worker run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
